# Airfocus API Configuration
AIRFOCUS_API_KEY = "your_airfocus_api_key_here"
AIRFOCUS_API_BASE_URL = "https://app.airfocus.com"

# Workspace Configuration
AIRFOCUS_WORKSPACE_ID = "your_workspace_id_here"

# Miro Configuration
# Option 1: Use access token directly
MIRO_ACCESS_TOKEN = "your_miro_access_token_here"

# Option 2: Use OAuth credentials (see README for setup)
# MIRO_CLIENT_ID = "your_client_id"
# MIRO_CLIENT_SECRET = "your_client_secret"

MIRO_API_BASE_URL = "https://api.miro.com/v2"

# Rate Limiting Configuration
AIRFOCUS_RATE_LIMIT_REQUESTS = 600
AIRFOCUS_RATE_LIMIT_WINDOW = 60
MIRO_RATE_LIMIT_REQUESTS = 100
MIRO_RATE_LIMIT_WINDOW = 60

# Request Configuration
REQUEST_TIMEOUT = 30.0
MAX_RETRIES = 3
RETRY_DELAY = 1.0
